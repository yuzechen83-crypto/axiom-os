# Axiom-OS LLM 配置 (axiom-os 二)
# 复制本文件为 axiom_os_llm.env 并填入真实密钥（axiom_os_llm.env 已 gitignore）

DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
KIMI_API_KEY=sk-your-kimi-api-key-here
# Kimi 端点（可选）：Kimi Code 用 https://api.kimi.com/coding/v1（仅限编码工具，通用调用可能 403）
# Moonshot 用 https://api.moonshot.ai/v1；Kimi K2 用 https://kimi-k2.ai/api/v1
# KIMI_BASE_URL=https://api.moonshot.ai/v1
